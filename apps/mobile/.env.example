# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Aether Mobile — Environment Variables
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Copy this file to .env
# All EXPO_PUBLIC_ vars are accessible in the app bundle.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── API ─────────────────────────────────────────
# Replace with your machine's local IP if testing on a physical device
# e.g., http://192.168.1.100:3000/api
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api

# ── WebSocket ───────────────────────────────────
EXPO_PUBLIC_WS_URL=http://localhost:3000
