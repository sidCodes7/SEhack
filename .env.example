# ──────────────────────────────────────────────
# AquaSentinel — Environment Variables
# Copy this to .env and fill in your credentials
# ──────────────────────────────────────────────

# Grok API (Avani uses this — x.ai)
XAI_API_KEY=

# Neon Postgres (Dev — neon.tech)
NEON_DATABASE_URL=

# Neo4j Aura (Dev — neo4j.io)
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=

# Email (Dev — Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_TO=

# Server
PORT=3001
NODE_ENV=development
